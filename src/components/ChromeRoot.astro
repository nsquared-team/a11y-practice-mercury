---
/**
 * ChromeRoot — the navigation/header/footer frame for the ROOT (inaccessible)
 * tree. Authored explicitly (NOT shared): it bakes in the frame-level WCAG
 * failures so the inaccessible tree is genuinely broken:
 *
 *   - No skip link (WCAG 2.4.1 Bypass Blocks — fail).
 *   - No landmarks: the nav, header, and main region are plain <div>s, and the
 *     nav has no list semantics (WCAG 1.3.1 / 4.1.2 — fail).
 *   - The current page is shown by colour only, with no aria-current
 *     (WCAG 1.4.1 Use of Colour — fail).
 *   - Main content has no programmatic identity / focus target.
 *   - Header search has no <label> and no search landmark (3.3.2 / 1.3.1).
 *   - Notifications is an icon-only control with no accessible name (1.1.1 / 4.1.2).
 *   - Footer status labels are low-contrast (1.4.3, reinforced by the override).
 *
 * Props: active (nav key for the current page).
 */
import { SITE, NAV } from '../data/ops.js';
import { getUnreadAlerts } from '../data/alerts.js';
import { getSitesByStatus } from '../data/sites.js';
import Icon from './Icon.astro';
const BASE = '/';
const { active } = Astro.props;
const unread = getUnreadAlerts().length;
const activeSites = getSitesByStatus('active').length;
---
<div class="sidebar">
  <div class="brand">
    <img class="brand__mark" src="/mercury-logo.svg" />
    <div>
      <div class="brand__name">{SITE.short}</div>
      <div class="brand__sub">Mining Operations</div>
    </div>
  </div>
  <div class="navlist">
    {NAV.map((item) => (
      <a class={`navlink${active === item.key ? ' is-active' : ''}`} href={BASE + item.path}>
        {item.label}
      </a>
    ))}
  </div>
</div>

<div class="topbar">
  {/* FAIL: search has no <label>, placeholder only, and no search landmark. */}
  <div class="topsearch">
    <span class="topsearch__icon"><Icon name="search" size={16} /></span>
    <input class="input topsearch__input" type="text" placeholder="Search sites, equipment, personnel…" />
  </div>
  <div class="topbar__meta">
    <span class="topbar__sol">{SITE.sol} · Day cycle</span>
    {/* FAIL: icon-only notifications with no accessible name. */}
    <a class="iconbtn" href={`${BASE}alerts/`}>
      <Icon name="bell" size={18} />
      {unread > 0 && <span class="iconbtn__badge">{unread}</span>}
    </a>
    <span class="badge badge--ok"><span class="badge__dot"></span>Systems nominal</span>
  </div>
</div>

<div class="main">
  <slot />
  <div class="footer footer--status">
    <span class="footstat"><span class="footstat__dot footstat__dot--ok"></span>System status: Operational</span>
    <span class="footstat">Active sites: {activeSites}</span>
    <span class="footstat">Last sync: 14:38 UTC</span>
    <span class="footstat">Connection: Stable</span>
    <span class="footstat footstat--end">{SITE.name} · {SITE.colony} · Telemetry is simulated.</span>
  </div>
</div>
