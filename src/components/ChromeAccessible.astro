---
/**
 * ChromeAccessible — the navigation/header/footer frame for the /accessible/
 * tree. Authored explicitly (NOT shared with the root tree): skip link, proper
 * landmarks, a real <nav> with list semantics and aria-current, discernible
 * link text, and a focusable <main>.
 *
 * Props: active (nav key for the current page).
 */
import { SITE, NAV } from '../data/ops.js';
import { getUnreadAlerts } from '../data/alerts.js';
import { getSitesByStatus } from '../data/sites.js';
import Icon from './Icon.astro';
const BASE = '/accessible/';
const { active } = Astro.props;
const unread = getUnreadAlerts().length;
const activeSites = getSitesByStatus('active').length;
---
<a class="skiplink pt-sr-only-focusable" href="#main">Skip to main content</a>

<nav class="sidebar" aria-label="Primary">
  <a class="brand" href={`${BASE}dashboard/`} aria-label={`${SITE.name} — dashboard home`}>
    <img class="brand__mark" src="/mercury-logo.svg" alt="" width="34" height="34" />
    <span>
      <span class="brand__name">{SITE.short}</span>
      <span class="brand__sub">Mining Operations</span>
    </span>
  </a>
  <ul class="navlist">
    {NAV.map((item) => (
      <li>
        <a
          class="navlink"
          href={BASE + item.path}
          aria-current={active === item.key ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<header class="topbar">
  <search class="topsearch">
    <label for="global-search" class="sr-only">Search sites, equipment, and personnel</label>
    <span class="topsearch__icon"><Icon name="search" size={16} /></span>
    <input id="global-search" class="input topsearch__input" type="search" name="q"
           placeholder="Search sites, equipment, personnel…" autocomplete="off" />
  </search>
  <div class="topbar__meta">
    <span class="topbar__sol" title={`${SITE.colony} · Mercury day cycle`}>{SITE.sol} · Day cycle</span>
    <a class="iconbtn" href={`${BASE}alerts/`} aria-label={`Notifications: ${unread} unread`}>
      <Icon name="bell" size={18} />
      {unread > 0 && <span class="iconbtn__badge" aria-hidden="true">{unread}</span>}
    </a>
    <span class="badge badge--ok"><span class="badge__dot" aria-hidden="true"></span>Systems nominal</span>
  </div>
</header>

<main class="main" id="main" tabindex="-1">
  <slot />
  <footer class="footer footer--status">
    <p class="footstat"><span class="footstat__dot footstat__dot--ok" aria-hidden="true"></span>System status: <strong>Operational</strong></p>
    <p class="footstat">Active sites: <strong>{activeSites}</strong></p>
    <p class="footstat">Last sync: <strong>14:38 UTC</strong></p>
    <p class="footstat">Connection: <strong>Stable</strong></p>
    <p class="footstat footstat--end">{SITE.name} · Accessible reference build. Telemetry is simulated.</p>
  </footer>
</main>
