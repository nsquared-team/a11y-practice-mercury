---
/**
 * Reports — ROOT (inaccessible) tree.  Pattern focus: SORTABLE DATA TABLE.
 *
 * Deliberate WCAG failures on this page:
 *  - The data uses a real <table> but the column header cells are <td> (no <th>,
 *    no scope) and there is NO <caption>, so rows/columns have no programmatic
 *    associations and the table has no name (1.3.1 Info & Relationships).
 *  - The sort affordance is a clickable <span class="sortbtn"> inside the header
 *    cell: it is not focusable and responds to click only, so keyboard users
 *    cannot sort (2.1.1 Keyboard) and it exposes no button role/name (4.1.2).
 *  - Sort direction is conveyed by a coloured ▲/▼ glyph only, and the sorted
 *    state is NOT exposed programmatically — there is no aria-sort, so AT users
 *    cannot tell which column/direction is active (4.1.2 / 1.4.1).
 *  - The Status column is coloured text only (red "Offline" etc.); the word is
 *    still present, so this is a minor secondary colour-reliance demo (1.4.1).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeRoot from '@components/ChromeRoot.astro';
import { SITE, SHIFT_REPORT } from '@data/ops.js';

// Initial sensible sort: by Output (tonnes) descending, in the static HTML.
const rows = [...SHIFT_REPORT.rows].sort((a, b) => b.tonnes - a.tonnes);

// FAIL (1.4.1): Status conveyed by coloured text only — no badge/icon/cue.
const statusColor = (s) =>
  s === 'Nominal' ? 'var(--ok-text)' : s === 'Degraded' ? 'var(--warn-text)' : 'var(--crit-text)';
---
<BaseLayout title="Reports — Mercury Mining Operations" variant="root">
  <div class="app">
    <ChromeRoot active="reports">
      <div class="pagehead">
        <h1>Shift Reports</h1>
        <p>Per-rig extraction output for the {SITE.colony}, {SITE.sol}.</p>
      </div>

      <p>
        Output, uptime and ore grade for every rig logged this sol across both
        shifts. Click a column heading to sort the table; click again to reverse
        the order. The table opens sorted by output, highest first.
      </p>

      <div class="card">
        <table class="data" id="report-table">
          <thead>
            <tr>
              {SHIFT_REPORT.columns.map((col) => (
                <td class={col.numeric ? 'num' : undefined} data-key={col.key} data-numeric={col.numeric ? 'true' : 'false'}>
                  <span class="sortbtn" data-sort>
                    {col.label}
                    <span class="sortbtn__arrow"></span>
                  </span>
                </td>
              ))}
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <td data-key="rig">{r.rig}</td>
                <td data-key="sector">{r.sector}</td>
                <td class="num" data-key="tonnes" data-value={r.tonnes}>{r.tonnes}</td>
                <td class="num" data-key="uptime" data-value={r.uptime}>{r.uptime.toFixed(1)}</td>
                <td class="num" data-key="grade" data-value={r.grade}>{r.grade.toFixed(1)}</td>
                <td data-key="status"><span style={`color:${statusColor(r.status)};font-weight:650`}>{r.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </ChromeRoot>
  </div>
</BaseLayout>

<script>
  const table = document.getElementById('report-table');
  if (table) {
    const tbody = table.querySelector('tbody');
    const headRow = table.querySelector('thead tr');
    const headers = Array.from(headRow.children);
    // initial state mirrors the static render: tonnes, descending.
    let activeKey = 'tonnes';
    let dir = 'desc';

    function render() {
      headers.forEach((cell) => {
        const arrow = cell.querySelector('.sortbtn__arrow');
        if (!arrow) return;
        if (cell.getAttribute('data-key') === activeKey) {
          arrow.textContent = dir === 'asc' ? '▲' : '▼';
        } else {
          arrow.textContent = '';
        }
      });

      const numeric = headers.find((c) => c.getAttribute('data-key') === activeKey)
        .getAttribute('data-numeric') === 'true';
      const rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        const ca = a.querySelector(`[data-key="${activeKey}"]`);
        const cb = b.querySelector(`[data-key="${activeKey}"]`);
        let va, vb;
        if (numeric) {
          va = parseFloat(ca.getAttribute('data-value'));
          vb = parseFloat(cb.getAttribute('data-value'));
        } else {
          va = ca.textContent.trim().toLowerCase();
          vb = cb.textContent.trim().toLowerCase();
        }
        if (va < vb) return dir === 'asc' ? -1 : 1;
        if (va > vb) return dir === 'asc' ? 1 : -1;
        return 0;
      });
      rows.forEach((r) => tbody.appendChild(r));
    }

    headers.forEach((cell) => {
      const btn = cell.querySelector('[data-sort]');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const key = cell.getAttribute('data-key');
        if (key === activeKey) {
          dir = dir === 'asc' ? 'desc' : 'asc';
        } else {
          activeKey = key;
          dir = 'asc';
        }
        render();
      });
    });

    render();
  }
</script>
