---
/**
 * Operator sign-in — ROOT (inaccessible) tree.  Pattern focus: FORMS.
 *
 * Fake auth (client-side only): any email containing "mercury" signs in and
 * redirects to the dashboard; anything else shows a failure message.
 *
 * Deliberate WCAG failures on this page:
 *  - The fields have NO associated <label> — placeholder text only
 *    (1.3.1 Info & Relationships, 3.3.2 Labels or Instructions, 4.1.2).
 *  - There is no <form>, and Sign in is a clickable <div>, so Enter does not
 *    submit and the control is not keyboard operable / has no role or name
 *    (2.1.1 Keyboard, 4.1.2 Name, Role, Value).
 *  - The failure message is a styled <div> toggled on with no live region and
 *    not associated with the field, so it is never announced (4.1.3, 3.3.1).
 *  - The card is barely opaque and there is no legibility scrim, so text sits
 *    low-contrast over the photo (1.4.3 Contrast). The global override also
 *    washes out the muted text.
 *  - Inputs omit autocomplete tokens (1.3.5 Identify Input Purpose).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@data/ops.js';
---
<BaseLayout title="Sign in — Mercury Mining Operations" variant="root">
  <div class="login-stage">
    <div class="login-card login-card--thin">
      <div class="brand">
        <div class="brand__mark">M</div>
        <div>
          <div class="brand__name">{SITE.short}</div>
          <div class="brand__sub">Mining Operations</div>
        </div>
      </div>

      <h1>Operator sign-in</h1>
      <p class="login-tagline">{SITE.colony}</p>

      <div id="error" class="login-error">Access denied — credentials not recognised for this mission.</div>
      <div id="success" class="login-success">Access granted. Routing to operations console…</div>

      <div class="field">
        <input id="email" class="input" type="text" placeholder="Operator email" />
      </div>
      <div class="field">
        <input id="password" class="input" type="password" placeholder="Passphrase" />
      </div>

      <div id="signin" class="btn btn--primary">Sign in</div>

      <p class="login-hint">Demo only — any email with “mercury” in it gets you in.</p>
      <p class="login-foot"><a href="/">Skip to the demo dashboard →</a></p>
    </div>
  </div>
</BaseLayout>

<script>
  const email = document.getElementById('email');
  const err = document.getElementById('error');
  const ok = document.getElementById('success');
  const btn = document.getElementById('signin');

  function attempt() {
    const value = (email.value || '').trim();
    const passes = /mercury/i.test(value);
    if (passes) {
      err.classList.remove('is-shown');
      ok.classList.add('is-shown');
      window.setTimeout(() => { window.location.href = '/'; }, 900);
    } else {
      ok.classList.remove('is-shown');
      err.classList.add('is-shown');
    }
  }

  // Click only — no real form, so keyboard / Enter does not submit (the failure).
  btn.addEventListener('click', attempt);
</script>
