---
/**
 * Operator sign-in — ACCESSIBLE tree.  Pattern focus: FORMS (corrected).
 *
 * Fake auth (client-side only): any email containing "mercury" signs in and
 * redirects to the accessible dashboard; anything else shows a failure message.
 *
 * Fixes mirrored against the root login:
 *  - Real <form> with a <label for> on every field and autocomplete tokens
 *    (1.3.1, 3.3.2, 1.3.5); Sign in is a <button type="submit"> so Enter works
 *    and it is keyboard operable with a proper role/name (2.1.1, 4.1.2).
 *  - The error is role="alert" (announced) and referenced by the email field's
 *    aria-describedby; on failure aria-invalid is set and focus moves to the
 *    field (4.1.3, 3.3.1).
 *  - A solid card + legibility scrim keep text contrast over the photo (1.4.3),
 *    and base.css keeps the visible focus ring.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@data/ops.js';
---
<BaseLayout title="Sign in — Discover Mercury Mining Operations" variant="accessible">
  <div class="login-stage login-stage--scrim">
    <div class="login-scrim" aria-hidden="true"></div>
    <main class="login-card login-card--solid" id="main">
      <div class="brand">
        <img class="brand__mark" src="/mercury-logo.svg" alt="" width="34" height="34" />
        <span>
          <span class="brand__name">{SITE.short}</span>
          <span class="brand__sub">Mining Operations</span>
        </span>
      </div>

      <h1>Operator sign-in</h1>
      <p class="login-tagline">{SITE.colony}</p>

      <p id="error" class="login-error" role="alert">Access denied — credentials not recognised for this mission.</p>
      <p id="success" class="login-success" role="status">Access granted. Routing to operations console…</p>

      <form id="login-form" novalidate>
        <div class="field">
          <label for="email">Operator email</label>
          <input id="email" class="input" type="email" name="email" autocomplete="email"
                 required aria-describedby="email-hint error" />
        </div>
        <div class="field">
          <label for="password">Passphrase</label>
          <input id="password" class="input" type="password" name="password"
                 autocomplete="current-password" required />
        </div>

        <button type="submit" class="btn btn--primary">Sign in</button>
      </form>

      <p id="email-hint" class="login-hint">Demo only — any email with “mercury” in it gets you in.</p>
      <p class="login-foot"><a href="/accessible/dashboard/">Skip to the demo dashboard →</a></p>
    </main>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('login-form');
  const email = document.getElementById('email');
  const err = document.getElementById('error');
  const ok = document.getElementById('success');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = (email.value || '').trim();
    const passes = /mercury/i.test(value);
    if (passes) {
      err.classList.remove('is-shown');
      email.removeAttribute('aria-invalid');
      ok.classList.add('is-shown');
      window.setTimeout(() => { window.location.href = '/accessible/dashboard/'; }, 900);
    } else {
      ok.classList.remove('is-shown');
      err.classList.add('is-shown');
      email.setAttribute('aria-invalid', 'true');
      email.focus();
    }
  });
</script>
