---
/**
 * Dashboard — ACCESSIBLE tree.  Pattern focus: CHARTS (corrected).
 *
 * Fixes mirrored against the root dashboard:
 *  - Each chart is role="img" with an aria-label summary AND a real data table
 *    (visually hidden with .sr-only) so the underlying numbers are available to
 *    assistive tech (1.1.1).
 *  - KPI deltas pair the colour/glyph with text ("up", "down", "no change") via
 *    sr-only text; the glyph is aria-hidden (1.4.1).
 *  - The critical-incident banner is role="alert" so it is announced (4.1.3).
 *  - Heading order is h1 → h2 → h3 with sectioned regions (1.3.1).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeAccessible from '@components/ChromeAccessible.astro';
import { SITE, KPIS, PRODUCTION_SERIES, STREAM_MIX } from '@data/ops.js';
import { linePlot, barPlot } from '@lib/chart.js';

const plot = linePlot(PRODUCTION_SERIES.points);
const bars = barPlot(STREAM_MIX.bars);
const barClass = { IL: 'bar--il', AN: 'bar--an', PX: 'bar--px', WI: 'bar--wi' };
const swatch = { IL: '#ff9e3d', AN: '#38e0c8', PX: '#5aa6ff', WI: '#ffc371' };
const peak = plot.xy.reduce((a, b) => (b.value > a.value ? b : a));
const trough = plot.xy.reduce((a, b) => (b.value < a.value ? b : a));
const deltaWord = (d) => (d > 0 ? 'up' : d < 0 ? 'down' : 'no change');
---
<BaseLayout title="Dashboard — Mercury Mining Operations" variant="accessible">
  <div class="app">
    <ChromeAccessible active="dashboard">
      <div class="pagehead">
        <h1>Operations Dashboard</h1>
        <p>Live extraction telemetry for the {SITE.colony}.</p>
      </div>

      <div class="banner banner--critical" role="alert">
        <span class="live-dot" aria-hidden="true"></span>
        Rig 07 auto-halted — drill head over-torque. Inspection crew dispatched.
      </div>

      <section aria-labelledby="kpi-h">
        <h2 id="kpi-h" class="sr-only">Key performance indicators</h2>
        <div class="grid grid--kpi" style="margin-bottom:1rem">
          {KPIS.map((k) => (
            <div class="card">
              <div class="kpi__label">{k.label}</div>
              <div class="kpi__value">{k.value} <span class="kpi__unit">{k.unit}</span></div>
              <div class={`kpi__delta ${k.delta > 0 ? 'kpi__delta--up' : k.delta < 0 ? 'kpi__delta--down' : 'kpi__delta--flat'}`}>
                <span aria-hidden="true">{k.delta > 0 ? '▲' : k.delta < 0 ? '▼' : '■'} {Math.abs(k.delta)}%</span>
                <span class="sr-only">{deltaWord(k.delta)} {Math.abs(k.delta)} percent versus previous sol</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section aria-labelledby="charts-h">
        <h2 id="charts-h" class="sr-only">Production charts</h2>
        <div class="grid grid--2">
          <div class="card">
            <div class="card__title"><h3 id="line-h">{PRODUCTION_SERIES.label}</h3></div>
            <svg class="chart" viewBox={`0 0 ${plot.width} ${plot.height}`} role="img"
                 aria-label={`Line chart of refined output per 2-hour window this sol. Peak ${peak.value} ${PRODUCTION_SERIES.unit} at ${peak.t}; low ${trough.value} ${PRODUCTION_SERIES.unit} at ${trough.t}. Full data in the table below.`}>
              <defs>
                <linearGradient id="area-grad" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#ff9e3d" stop-opacity="0.35" />
                  <stop offset="100%" stop-color="#ff9e3d" stop-opacity="0" />
                </linearGradient>
              </defs>
              <line class="chart__axis" x1={plot.pad} y1={plot.height - plot.pad} x2={plot.width - plot.pad} y2={plot.height - plot.pad} />
              <path class="chart__area" d={plot.area} />
              <path class="chart__line" d={plot.line} />
              {plot.xy.map((p) => <circle class="chart__dot" cx={p.x} cy={p.y} r="3" />)}
              {plot.xy.filter((_, i) => i % 2 === 0).map((p) => (
                <text class="chart__label" x={p.x} y={plot.height - plot.pad + 14} text-anchor="middle">{p.t}</text>
              ))}
            </svg>
            <table class="data sr-only">
              <caption>Refined output per 2-hour window (tonnes)</caption>
              <thead><tr><th scope="col">Window</th><th scope="col" class="num">Output (t)</th></tr></thead>
              <tbody>
                {PRODUCTION_SERIES.points.map((p) => (
                  <tr><th scope="row">{p.t}</th><td class="num">{p.value}</td></tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="card">
            <div class="card__title"><h3 id="bars-h">{STREAM_MIX.label}</h3></div>
            <svg class="chart" viewBox={`0 0 ${bars.width} ${bars.height}`} role="img"
                 aria-label={`Bar chart of output by mineral stream this sol, in tonnes. ${STREAM_MIX.bars.map((b) => `${b.stream} ${b.value}`).join(', ')}. Full data in the table below.`}>
              <line class="chart__axis" x1={bars.pad} y1={bars.baseline} x2={bars.width - bars.pad} y2={bars.baseline} />
              {bars.rects.map((r) => <rect class={barClass[r.code]} x={r.x} y={r.y} width={r.w} height={r.h} rx="3" />)}
            </svg>
            <div class="legend" aria-hidden="true">
              {STREAM_MIX.bars.map((b) => (
                <span class="legend__item">
                  <span class="legend__swatch" style={`background:${swatch[b.code]}`}></span>
                  {b.stream}
                </span>
              ))}
            </div>
            <table class="data sr-only">
              <caption>Output by mineral stream (tonnes per sol)</caption>
              <thead><tr><th scope="col">Stream</th><th scope="col" class="num">Output (t)</th></tr></thead>
              <tbody>
                {STREAM_MIX.bars.map((b) => (
                  <tr><th scope="row">{b.stream}</th><td class="num">{b.value}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </ChromeAccessible>
  </div>
</BaseLayout>
