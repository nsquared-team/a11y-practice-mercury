---
/**
 * Dashboard — ACCESSIBLE tree.  Patterns: CHARTS + status grid + commodity
 * widget + alert feed (all corrected, one-to-one with the root dashboard).
 *
 * Fixes:
 *  - Banner is role="alert" (4.1.3).
 *  - KPI deltas pair glyph (aria-hidden) with sr-only direction text (1.4.1).
 *  - Extraction chart is role="img" + aria-label summary + an sr-only data
 *    table of every value (1.1.1).
 *  - Equipment grid is a list; each cell has an sr-only "name: status" name and
 *    a letter code so status is not by colour alone (1.1.1, 1.4.1).
 *  - Alert feed is a <ul> with a text severity badge per item (1.3.1, 1.4.1).
 *  - Commodity change pairs ▲/▼ (aria-hidden) with sr-only direction text and
 *    keeps sufficient contrast (1.4.1, 1.4.3).
 *  - Sectioned with h1 → h2 → h3 heading order (1.3.1).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeAccessible from '@components/ChromeAccessible.astro';
import { SITE, KPIS, EXTRACTION_SERIES } from '@data/ops.js';
import { commoditiesData, getRecentAlerts, formatAlertTime } from '@data/alerts.js';
import { equipmentData } from '@data/equipment.js';
import { multiSeriesPlot } from '@lib/chart.js';

const plot = multiSeriesPlot(EXTRACTION_SERIES.labels, EXTRACTION_SERIES.series);
const recent = getRecentAlerts(4);
const deltaWord = (d) => (d > 0 ? 'up' : d < 0 ? 'down' : 'no change');
const EQ = {
  operational: { code: 'O', label: 'Operational' },
  idle: { code: 'I', label: 'Idle' },
  maintenance: { code: 'M', label: 'Maintenance' },
  offline: { code: 'X', label: 'Offline' },
};
const SEV = {
  critical: { cls: 'crit', label: 'Critical' },
  warning: { cls: 'warn', label: 'Warning' },
  info: { cls: 'muted', label: 'Info' },
  success: { cls: 'ok', label: 'Success' },
};
const peak = (s) => Math.max(...s.values);
const chartLabel = `Area chart of extraction rate in kilograms per hour by commodity over the last 24 hours. ${EXTRACTION_SERIES.series.map((s) => `${s.label} peaks at ${peak(s)}`).join('; ')}. Full data in the table below.`;
---
<BaseLayout title="Dashboard — Discover Mercury Mining Operations" variant="accessible">
  <div class="app">
    <ChromeAccessible active="dashboard">
      <div class="pagehead">
        <h1>Operations Dashboard</h1>
        <p>Live extraction telemetry for the {SITE.colony}.</p>
      </div>

      <div class="banner banner--critical" role="alert">
        <span class="live-dot" aria-hidden="true"></span>
        Rig 07 auto-halted — drill head over-torque. Inspection crew dispatched.
      </div>

      <section aria-labelledby="kpi-h">
        <h2 id="kpi-h" class="sr-only">Key performance indicators</h2>
        <div class="grid grid--kpi" style="margin-bottom:1rem">
          {KPIS.map((k) => (
            <div class="card">
              <div class="kpi__label">{k.label}</div>
              <div class="kpi__value">{k.value} <span class="kpi__unit">{k.unit}</span></div>
              <div class={`kpi__delta ${k.delta > 0 ? 'kpi__delta--up' : k.delta < 0 ? 'kpi__delta--down' : 'kpi__delta--flat'}`}>
                <span aria-hidden="true">{k.delta > 0 ? '▲' : k.delta < 0 ? '▼' : '■'} {Math.abs(k.delta)}%</span>
                <span class="sr-only">{deltaWord(k.delta)} {Math.abs(k.delta)} percent versus previous sol</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section aria-labelledby="ops-h">
        <h2 id="ops-h" class="sr-only">Extraction and recent alerts</h2>
        <div class="grid grid--2">
          <div class="card">
            <div class="card__title"><h3 id="chart-h">{EXTRACTION_SERIES.label}</h3></div>
            <svg class="chart" viewBox={`0 0 ${plot.width} ${plot.height}`} role="img" aria-label={chartLabel}>
              <line class="chart__axis" x1={plot.pad} y1={plot.baseline} x2={plot.width - plot.pad} y2={plot.baseline} />
              {plot.series.map((s) => (
                <g>
                  <path class="chart__series-area" d={s.area} fill={s.color} />
                  <path d={s.line} fill="none" stroke={s.color} stroke-width="2.5" />
                </g>
              ))}
              {plot.labels.filter((_, i) => i % 2 === 0).map((t, i) => (
                <text class="chart__label" x={plot.x[i * 2]} y={plot.baseline + 14} text-anchor="middle">{t}</text>
              ))}
            </svg>
            <div class="legend" aria-hidden="true">
              {plot.series.map((s) => (
                <span class="legend__item"><span class="legend__swatch" style={`background:${s.color}`}></span>{s.label}</span>
              ))}
            </div>
            <table class="data sr-only">
              <caption>Extraction rate (kg/h) by commodity over 24 hours</caption>
              <thead>
                <tr>
                  <th scope="col">Time</th>
                  {EXTRACTION_SERIES.series.map((s) => <th scope="col" class="num">{s.label}</th>)}
                </tr>
              </thead>
              <tbody>
                {EXTRACTION_SERIES.labels.map((t, i) => (
                  <tr>
                    <th scope="row">{t}</th>
                    {EXTRACTION_SERIES.series.map((s) => <td class="num">{s.values[i]}</td>)}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="card">
            <div class="card__title"><h3>Recent alerts</h3></div>
            <ul class="minifeed">
              {recent.map((a) => (
                <li class={`minialert minialert--${a.severity}`}>
                  <p class="minialert__title">
                    <span class={`badge badge--${SEV[a.severity].cls}`}>{SEV[a.severity].label}</span>
                    {a.title}
                  </p>
                  <span class="minialert__time">{formatAlertTime(a.timestamp)}</span>
                  <p class="minialert__msg">{a.message}</p>
                </li>
              ))}
            </ul>
            <a class="feedlink" href="/accessible/alerts/">View all alerts →</a>
          </div>
        </div>
      </section>

      <section aria-labelledby="fleet-h">
        <h2 id="fleet-h" class="sr-only">Equipment and commodities</h2>
        <div class="grid grid--2" style="margin-top:1rem">
          <div class="card">
            <div class="card__title"><h3 id="eq-h">Equipment status</h3></div>
            <ul class="eqgrid" aria-labelledby="eq-h">
              {equipmentData.map((e) => (
                <li class={`eqcell eqcell--${e.status}`}>
                  <span aria-hidden="true">{EQ[e.status].code}</span>
                  <span class="sr-only">{e.name}: {EQ[e.status].label}</span>
                </li>
              ))}
            </ul>
            <div class="eqlegend">
              <span class="legend__item"><span class="legend__swatch eqcell--operational" aria-hidden="true">O</span>Operational</span>
              <span class="legend__item"><span class="legend__swatch eqcell--idle" aria-hidden="true">I</span>Idle</span>
              <span class="legend__item"><span class="legend__swatch eqcell--maintenance" aria-hidden="true">M</span>Maintenance</span>
              <span class="legend__item"><span class="legend__swatch eqcell--offline" aria-hidden="true">X</span>Offline</span>
            </div>
          </div>

          <div class="card">
            <div class="card__title"><h3>Commodity prices</h3></div>
            <ul class="commoditylist">
              {commoditiesData.map((c) => (
                <li class="commodity">
                  <span class="commodity__name">
                    {c.name}
                    <span class="commodity__sym">{c.symbol}</span>
                  </span>
                  <span class="commodity__price">{c.price.toLocaleString()} ¢</span>
                  <span class={`commodity__chg commodity__chg--${c.trend === 'up' ? 'up' : c.trend === 'down' ? 'down' : 'stable'}`}>
                    <span aria-hidden="true">{c.trend === 'up' ? '▲' : c.trend === 'down' ? '▼' : '■'}</span>
                    <span class="sr-only">{c.trend === 'up' ? 'up' : c.trend === 'down' ? 'down' : 'unchanged'}</span>
                    {c.change24h > 0 ? '+' : ''}{c.change24h}%
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    </ChromeAccessible>
  </div>
</BaseLayout>
