---
/**
 * Reports — ACCESSIBLE tree.  Patterns: TABS + ACCORDION + CHARTS +
 * data TABLE + export MODAL (all corrected, one-to-one with the root page).
 *
 * Fixes:
 *  - Page tabs use role="tablist"/"tab"/"tabpanel" with aria-selected, roving
 *    tabindex, and arrow/Home/End navigation.
 *  - Builder accordion headers are real <button aria-expanded aria-controls>;
 *    selects have <label for>; metrics are an id'd checkbox + <label> set in a
 *    <fieldset><legend>.
 *  - Preview + analytics charts are role="img" with aria-label and a paired
 *    visually-hidden data table.
 *  - Analytics line/bar toggle uses real <button aria-pressed> in a named group.
 *  - Saved-reports actions are real <button>s with name-bearing aria-label; the
 *    table has a caption, th scope="col" and th scope="row".
 *  - Export modal is role="dialog" aria-modal with focus management, Escape, and
 *    trap; columns group is a <fieldset><legend> with id'd checkbox + <label>.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeAccessible from '@components/ChromeAccessible.astro';
import { reportMetrics, savedReports, getReportTypeLabel, getVisualizationLabel } from '@data/reports.js';
import { EXTRACTION_SERIES } from '@data/ops.js';

const types = Object.keys(reportMetrics);
const ranges = [['7days', 'Last 7 days'], ['30days', 'Last 30 days'], ['90days', 'Last quarter']];
const vizzes = [['line', 'Line'], ['bar', 'Bar'], ['area', 'Area']];
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const fmt = (iso) => { const d = new Date(iso); return `${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`; };
const PREV = { labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'], values: [3200, 3450, 3380, 3610, 3720, 3290, 3510] };
const metricsByType = reportMetrics;
const pageTabs = [['builder', 'Report Builder'], ['saved', 'Saved Reports'], ['analytics', 'Analytics']];
---
<BaseLayout title="Reports — Discover Mercury Mining Operations" variant="accessible">
  <div class="app">
    <ChromeAccessible active="reports">
      <div class="pagehead">
        <h1>Reports &amp; Analytics</h1>
        <p>Build custom reports, manage saved reports, and compare performance.</p>
      </div>

      <div class="tabs">
        <div class="tablist" role="tablist" aria-label="Reports views" id="ptabs">
          {pageTabs.map(([k, l], i) => (
            <button role="tab" id={`pt-${k}`} aria-controls={`pp-${k}`} aria-selected={i === 0 ? 'true' : 'false'} tabindex={i === 0 ? '0' : '-1'} class={`tab${i === 0 ? ' is-active' : ''}`} data-panel={k}>{l}</button>
          ))}
        </div>

        <div class="tabpanel" role="tabpanel" id="pp-builder" aria-labelledby="pt-builder" tabindex="0" data-panel="builder">
          <div class="builder">
            <div>
              <div class="acc is-open" data-acc>
                <button type="button" class="acc__head" data-accbtn aria-expanded="true" aria-controls="acc-type">Report type <span class="acc__arrow" aria-hidden="true">▸</span></button>
                <div class="acc__panel" id="acc-type">
                  <label class="field__label" for="b-type">Report type</label>
                  <select class="select" id="b-type">{types.map((t) => <option value={t}>{getReportTypeLabel(t)}</option>)}</select>
                </div>
              </div>
              <div class="acc" data-acc>
                <button type="button" class="acc__head" data-accbtn aria-expanded="false" aria-controls="acc-range">Date range <span class="acc__arrow" aria-hidden="true">▸</span></button>
                <div class="acc__panel" id="acc-range" hidden>
                  <label class="field__label" for="b-range">Date range</label>
                  <select class="select" id="b-range">{ranges.map(([v, l]) => <option value={v}>{l}</option>)}</select>
                </div>
              </div>
              <div class="acc" data-acc>
                <button type="button" class="acc__head" data-accbtn aria-expanded="false" aria-controls="acc-metrics">Metrics <span class="acc__arrow" aria-hidden="true">▸</span></button>
                <div class="acc__panel" id="acc-metrics" hidden>
                  <fieldset class="filtergroup" id="b-metrics-fs">
                    <legend class="filtergroup__label">Metrics</legend>
                    <div id="b-metrics"></div>
                  </fieldset>
                </div>
              </div>
              <div class="acc" data-acc>
                <button type="button" class="acc__head" data-accbtn aria-expanded="false" aria-controls="acc-viz">Visualization <span class="acc__arrow" aria-hidden="true">▸</span></button>
                <div class="acc__panel" id="acc-viz" hidden>
                  <label class="field__label" for="b-viz">Visualization</label>
                  <select class="select" id="b-viz">{vizzes.map(([v, l]) => <option value={v} selected={v === 'area'}>{l}</option>)}</select>
                </div>
              </div>
            </div>
            <div class="card">
              <div class="card__title"><h3 id="prev-title">Extraction · Last 7 days</h3></div>
              <div class="previewstats" id="prev-stats"></div>
              <div id="prev-chart"></div>
              <table class="data sr-only" id="prev-table">
                <caption>Preview values for the selected report, last 7 days</caption>
                <thead><tr><th scope="col">Day</th><th scope="col">Value</th></tr></thead>
                <tbody>
                  {PREV.labels.map((l, i) => (
                    <tr><th scope="row">{l}</th><td>{PREV.values[i].toLocaleString()}</td></tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="tabpanel" role="tabpanel" id="pp-saved" aria-labelledby="pt-saved" tabindex="0" data-panel="saved" hidden>
          <div class="tablewrap">
            <table class="data">
              <caption>Saved reports with schedule, last run, and actions</caption>
              <thead><tr><th scope="col">Report</th><th scope="col">Type</th><th scope="col">Schedule</th><th scope="col">Last run</th><th scope="col">Actions</th></tr></thead>
              <tbody>
                {savedReports.map((r) => (
                  <tr>
                    <th scope="row">{r.name}</th>
                    <td>{getReportTypeLabel(r.type)}</td>
                    <td>{r.schedule}</td>
                    <td>{r.lastRun ? fmt(r.lastRun) : '—'}</td>
                    <td>
                      <span class="savedactions">
                        <button type="button" class="pagebtn run-report" data-id={r.id} aria-label={`Run ${r.name}`}><span aria-hidden="true">▶</span></button>
                        <button type="button" class="pagebtn export-report" data-id={r.id} data-type={r.type} data-name={r.name} aria-label={`Export ${r.name}`}><span aria-hidden="true">⭳</span></button>
                        <button type="button" class="pagebtn delete-report" data-id={r.id} aria-label={`Delete ${r.name}`}><span aria-hidden="true">✕</span></button>
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="tabpanel" role="tabpanel" id="pp-analytics" aria-labelledby="pt-analytics" tabindex="0" data-panel="analytics" hidden>
          <div class="toolbar">
            <span class="togglegroup" role="group" aria-label="Chart type">
              <button type="button" class="pagebtn is-current" data-viz="line" aria-pressed="true">Line</button>
              <button type="button" class="pagebtn" data-viz="bar" aria-pressed="false">Bar</button>
            </span>
          </div>
          <div class="card">
            <div class="card__title"><h3>Output by commodity</h3></div>
            <div id="cmp-chart"></div>
            <table class="data sr-only">
              <caption>{EXTRACTION_SERIES.label}</caption>
              <thead>
                <tr>
                  <th scope="col">Time</th>
                  {EXTRACTION_SERIES.series.map((s) => <th scope="col">{s.label} ({EXTRACTION_SERIES.unit})</th>)}
                </tr>
              </thead>
              <tbody>
                {EXTRACTION_SERIES.labels.map((t, i) => (
                  <tr>
                    <th scope="row">{t}</th>
                    {EXTRACTION_SERIES.series.map((s) => <td>{s.values[i]}</td>)}
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="legend">
              {EXTRACTION_SERIES.series.map((s) => (
                <span class="legend__item"><span class="legend__swatch" style={`background:${s.color}`} aria-hidden="true"></span>{s.label}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </ChromeAccessible>
  </div>

  <div class="modal-backdrop" id="xbackdrop" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="xtitle">
      <div class="modal__head">
        <h2 class="modal__title" id="xtitle" tabindex="-1">Export report</h2>
        <button class="modal__close" id="xclose" type="button" aria-label="Close dialog"><span aria-hidden="true">✕</span></button>
      </div>
      <div class="modal__body">
        <fieldset class="filtergroup">
          <legend class="filtergroup__label">Columns to export</legend>
          <div id="x-metrics"></div>
        </fieldset>
      </div>
      <div class="modal__foot">
        <button class="btn btn--ghost" type="button" id="xcancel">Cancel</button>
        <button class="btn btn--primary" type="button" id="xgo">Export CSV</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ metricsByType, EXTRACTION_SERIES, PREV, typeLabels: Object.fromEntries(types.map((t) => [t, getReportTypeLabel(t)])) }}>
  function wireTabs(listEl, onSelect) {
    const tabsArr = Array.from(listEl.querySelectorAll('[role="tab"]'));
    function select(tab, focus) {
      tabsArr.forEach((t) => {
        const on = t === tab;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
        t.classList.toggle('is-active', on);
      });
      if (focus) tab.focus();
      onSelect(tab);
    }
    listEl.addEventListener('click', (e) => { const t = e.target.closest('[role="tab"]'); if (t) select(t, false); });
    listEl.addEventListener('keydown', (e) => {
      const i = tabsArr.indexOf(document.activeElement);
      if (i < 0) return;
      let n = null;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') n = (i + 1) % tabsArr.length;
      else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') n = (i - 1 + tabsArr.length) % tabsArr.length;
      else if (e.key === 'Home') n = 0;
      else if (e.key === 'End') n = tabsArr.length - 1;
      if (n !== null) { e.preventDefault(); select(tabsArr[n], true); }
    });
    return select;
  }

  // Page tabs
  const ptabs = document.getElementById('ptabs');
  wireTabs(ptabs, (tab) => {
    const p = tab.dataset.panel;
    document.querySelectorAll('.tabpanel[data-panel]').forEach((pn) => (pn.hidden = pn.dataset.panel !== p));
  });

  // Accordion: real buttons with aria-expanded + controlled panel.
  document.querySelectorAll('[data-acc]').forEach((acc) => {
    const btn = acc.querySelector('[data-accbtn]');
    const pan = acc.querySelector('.acc__panel');
    btn.addEventListener('click', () => {
      const open = acc.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      pan.hidden = !open;
    });
  });

  // Chart builder
  function chartSVG(values, labels, viz, label) {
    const W = 560, H = 220, pad = 34, innerW = W - pad * 2, innerH = H - pad * 2;
    const max = Math.max(...values), min = Math.min(...values, 0), span = (max - min) || 1;
    const x = (i) => pad + (i / (values.length - 1)) * innerW, y = (v) => pad + (1 - (v - min) / span) * innerH;
    let body = '';
    if (viz === 'bar') {
      const gap = innerW / values.length, bw = gap * 0.6;
      values.forEach((v, i) => { const h = (v - min) / span * innerH; body += `<rect x="${(pad + i * gap + gap * 0.2).toFixed(1)}" y="${(pad + innerH - h).toFixed(1)}" width="${bw.toFixed(1)}" height="${h.toFixed(1)}" rx="3" fill="#ff9e3d"/>`; });
    } else {
      const line = values.map((v, i) => `${i ? 'L' : 'M'}${x(i).toFixed(1)},${y(v).toFixed(1)}`).join(' ');
      if (viz === 'area') body += `<path d="${line} L${x(values.length - 1).toFixed(1)},${pad + innerH} L${x(0).toFixed(1)},${pad + innerH} Z" fill="#ff9e3d" fill-opacity="0.15"/>`;
      body += `<path d="${line}" fill="none" stroke="#ff9e3d" stroke-width="2.5"/>`;
    }
    const lab = labels.map((l, i) => `<text class="chart__label" x="${x(i).toFixed(1)}" y="${H - pad + 14}" text-anchor="middle">${l}</text>`).join('');
    return `<svg viewBox="0 0 ${W} ${H}" class="chart" role="img" aria-label="${label}"><line class="chart__axis" x1="${pad}" y1="${pad + innerH}" x2="${W - pad}" y2="${pad + innerH}"/>${body}${lab}</svg>`;
  }
  function renderBuilder() {
    const type = document.getElementById('b-type').value, viz = document.getElementById('b-viz').value;
    const range = document.getElementById('b-range');
    const rangeText = range.options[range.selectedIndex].text;
    document.getElementById('prev-title').textContent = `${typeLabels[type]} · ${rangeText}`;
    const total = PREV.values.reduce((a, b) => a + b, 0), avg = Math.round(total / PREV.values.length), peak = Math.max(...PREV.values);
    document.getElementById('prev-stats').innerHTML = [['Total', total.toLocaleString()], ['Average', avg.toLocaleString()], ['Peak', peak.toLocaleString()]]
      .map(([l, v]) => `<div class="previewstat"><div class="previewstat__label">${l}</div><div class="previewstat__value">${v}</div></div>`).join('');
    const vizText = { line: 'Line chart', bar: 'Bar chart', area: 'Area chart' }[viz];
    const label = `${vizText} of ${typeLabels[type]} preview, ${rangeText}, ranging ${Math.min(...PREV.values).toLocaleString()} to ${peak.toLocaleString()}. See the data table below for values.`;
    document.getElementById('prev-chart').innerHTML = chartSVG(PREV.values, PREV.labels, viz, label);
  }
  function renderMetrics(containerId, type) {
    const list = metricsByType[type] || [];
    document.getElementById(containerId).innerHTML = list.map((m, i) =>
      `<label class="chk" for="m-${containerId}-${i}"><input type="checkbox" id="m-${containerId}-${i}" value="${m.id}" checked> ${m.name}${m.unit ? ` (${m.unit})` : ''}</label>`).join('');
  }
  document.getElementById('b-type').addEventListener('change', () => { renderMetrics('b-metrics', document.getElementById('b-type').value); renderBuilder(); });
  document.getElementById('b-viz').addEventListener('change', renderBuilder);
  document.getElementById('b-range').addEventListener('change', renderBuilder);
  renderMetrics('b-metrics', document.getElementById('b-type').value);
  renderBuilder();

  // Analytics comparison toggle
  function cmpLabel(viz) {
    const S = EXTRACTION_SERIES.series;
    const names = S.map((s) => s.label).join(', ');
    return `${viz === 'bar' ? 'Bar' : 'Line'} chart of output by commodity (${names}) over 24 hours, in ${EXTRACTION_SERIES.unit}. See the data table below for values.`;
  }
  function renderCmp(viz) {
    const S = EXTRACTION_SERIES.series, labels = EXTRACTION_SERIES.labels;
    const W = 640, H = 240, pad = 34, innerW = W - pad * 2, innerH = H - pad * 2;
    const max = Math.max(...S.flatMap((s) => s.values)) || 1;
    let body = '';
    if (viz === 'bar') {
      const totals = S.map((s) => s.values.reduce((a, b) => a + b, 0)); const tmax = Math.max(...totals);
      const gap = innerW / totals.length, bw = gap * 0.5;
      totals.forEach((v, i) => { const h = v / tmax * innerH; body += `<rect x="${(pad + i * gap + gap * 0.25).toFixed(1)}" y="${(pad + innerH - h).toFixed(1)}" width="${bw.toFixed(1)}" height="${h.toFixed(1)}" rx="3" fill="${S[i].color}"/>`; });
    } else {
      S.forEach((s) => {
        const line = s.values.map((v, i) => `${i ? 'L' : 'M'}${(pad + i / (labels.length - 1) * innerW).toFixed(1)},${(pad + (1 - v / max) * innerH).toFixed(1)}`).join(' ');
        body += `<path d="${line}" fill="none" stroke="${s.color}" stroke-width="2.5"/>`;
      });
    }
    document.getElementById('cmp-chart').innerHTML = `<svg viewBox="0 0 ${W} ${H}" class="chart" role="img" aria-label="${cmpLabel(viz)}"><line class="chart__axis" x1="${pad}" y1="${pad + innerH}" x2="${W - pad}" y2="${pad + innerH}"/>${body}</svg>`;
  }
  document.querySelectorAll('[data-viz]').forEach((b) => b.addEventListener('click', () => {
    document.querySelectorAll('[data-viz]').forEach((x) => { x.classList.remove('is-current'); x.setAttribute('aria-pressed', 'false'); });
    b.classList.add('is-current');
    b.setAttribute('aria-pressed', 'true');
    renderCmp(b.dataset.viz);
  }));
  renderCmp('line');

  // Accessible export modal: dialog semantics, focus mgmt, Esc, trap.
  const xback = document.getElementById('xbackdrop');
  const xmodal = xback.querySelector('.modal');
  const xtitle = document.getElementById('xtitle');
  let lastFocused = null;
  function focusable() {
    return Array.from(xmodal.querySelectorAll('a[href],button:not([disabled]),input:not([disabled]),[tabindex]:not([tabindex="-1"])')).filter((el) => el.offsetParent !== null);
  }
  function onKeydown(e) {
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'Tab') {
      const f = focusable(); if (!f.length) return;
      const first = f[0], last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }
  function open(type, trigger) {
    const list = metricsByType[type] || metricsByType[Object.keys(metricsByType)[0]];
    document.getElementById('x-metrics').innerHTML = list.map((m, i) =>
      `<label class="chk" for="xm-${i}"><input type="checkbox" id="xm-${i}" value="${m.id}" checked> ${m.name}</label>`).join('');
    lastFocused = trigger;
    xback.hidden = false;
    document.addEventListener('keydown', onKeydown);
    xtitle.focus();
  }
  function close() {
    xback.hidden = true;
    document.removeEventListener('keydown', onKeydown);
    if (lastFocused) lastFocused.focus();
  }
  document.querySelectorAll('.export-report').forEach((b) => b.addEventListener('click', () => open(b.dataset.type || 'extraction', b)));
  document.getElementById('xclose').addEventListener('click', close);
  document.getElementById('xcancel').addEventListener('click', close);
  document.getElementById('xgo').addEventListener('click', close);
  xback.addEventListener('click', (e) => { if (e.target === xback) close(); });
</script>
