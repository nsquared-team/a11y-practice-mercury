---
/**
 * Settings — ACCESSIBLE tree.  Pattern focus: FORMS + TABS & PANELS (corrected).
 *
 * Fixes mirrored against the root settings page:
 *  TABS:
 *   - Proper APG tabs: role="tablist" (with aria-label), each tab a
 *     <button role="tab" aria-selected aria-controls id> with roving tabindex
 *     (selected = 0, others = -1) (4.1.2).
 *   - Full keyboard support: ArrowLeft/Right + Home/End move and activate, and
 *     activation focuses the panel (2.1.1).
 *   - Selection conveyed by aria-selected (and style), not colour alone (1.4.1).
 *   - Panels are <div role="tabpanel" aria-labelledby tabindex="0" hidden> when
 *     inactive.
 *  FORMS:
 *   - Every control has a real <label for>; related controls are grouped in a
 *     <fieldset><legend> (1.3.1 / 3.3.2 / 4.1.2).
 *   - The "Shift supervisor" field is required + aria-describedby its hint; on
 *     invalid submit it gets aria-invalid="true", focus moves to it, and a
 *     role="alert" error referenced by aria-describedby is shown
 *     (3.3.1 / 4.1.3).
 *   - Checkboxes are real <input type="checkbox" id> + <label> (2.1.1 / 4.1.2).
 *   - "Save" is a real <button type="submit" class="btn btn--primary"> (4.1.2).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeAccessible from '@components/ChromeAccessible.astro';
import { RIGS, SETTINGS_TABS } from '@data/ops.js';
---
<BaseLayout title="Settings — Discover Mercury Mining Operations" variant="accessible">
  <div class="app">
    <ChromeAccessible active="settings">
      <div class="pagehead">
        <h1>Settings</h1>
        <p>Configure rig targets, alert thresholds, and crew assignments for the extraction complex.</p>
      </div>

      <div class="tabs">
        <div class="tablist" role="tablist" aria-label="Settings sections">
          {SETTINGS_TABS.map((t, i) => (
            <button
              class="tab"
              role="tab"
              type="button"
              id={`tab-${t.key}`}
              aria-controls={`panel-${t.key}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              tabindex={i === 0 ? '0' : '-1'}
              data-tab={t.key}
            >{t.label}</button>
          ))}
        </div>

        {/* General */}
        <div
          class="tabpanel"
          role="tabpanel"
          id="panel-general"
          aria-labelledby="tab-general"
          tabindex="0"
          data-panel="general"
        >
          <form id="rig-form" class="stack" novalidate>
            <div class="field">
              <label class="field__label" for="rig">Active rig</label>
              <select class="select" name="rig" id="rig">
                <option value="" disabled selected>Choose a rig…</option>
                {RIGS.map((r) => <option value={r.id}>{r.label}</option>)}
              </select>
            </div>

            <div class="field">
              <label class="field__label" for="target">Target output (t/sol)</label>
              <input class="input" type="number" name="target" id="target" />
            </div>

            <div class="field">
              <label class="field__label" for="sup">Shift supervisor</label>
              <input
                class="input"
                type="text"
                name="supervisor"
                id="sup"
                required
                aria-describedby="sup-hint sup-err"
              />
              <p class="field__hint" id="sup-hint">Name of the supervisor accountable for this rig this sol.</p>
              {/* Error referenced by aria-describedby; role="alert" announces it. */}
              <p class="field__error" id="sup-err" role="alert" hidden>Shift supervisor is required.</p>
            </div>

            <fieldset>
              <legend>Options</legend>
              <div class="checkrow">
                <input type="checkbox" name="autohalt" id="autohalt" />
                <label for="autohalt">Auto-halt on over-torque</label>
              </div>
              <div class="checkrow">
                <input type="checkbox" name="email" id="email" />
                <label for="email">Email me critical alerts</label>
              </div>
            </fieldset>

            <button type="submit" class="btn btn--primary" id="save-btn">Save changes</button>
          </form>
        </div>

        {/* Alert Thresholds */}
        <div
          class="tabpanel"
          role="tabpanel"
          id="panel-thresholds"
          aria-labelledby="tab-thresholds"
          tabindex="0"
          data-panel="thresholds"
          hidden
        >
          <div class="stack">
            <div class="field">
              <label class="field__label" for="coreFloor">Core temp margin floor (°C)</label>
              <input class="input" type="number" name="coreFloor" id="coreFloor" value="25" />
            </div>
            <div class="field">
              <label class="field__label" for="solarFloor">Solar output floor (MW)</label>
              <input class="input" type="number" name="solarFloor" id="solarFloor" value="80" />
            </div>
            <div class="field">
              <label class="field__label" for="torqueCeil">Drill torque ceiling (kN·m)</label>
              <input class="input" type="number" name="torqueCeil" id="torqueCeil" value="240" />
            </div>
          </div>
        </div>

        {/* Crew & Shifts */}
        <div
          class="tabpanel"
          role="tabpanel"
          id="panel-crew"
          aria-labelledby="tab-crew"
          tabindex="0"
          data-panel="crew"
          hidden
        >
          <dl>
            <dt>Shift A supervisor</dt>
            <dd>K. Okonkwo</dd>
            <dt>Shift B supervisor</dt>
            <dd>R. Vasquez</dd>
            <dt>Crew on shift</dt>
            <dd>18 of 24</dd>
            <dt>Next handover</dt>
            <dd>Sol 4,182 · 22:00</dd>
          </dl>
        </div>
      </div>
    </ChromeAccessible>
  </div>
</BaseLayout>

<script>
  // --- Tabs: APG pattern with roving tabindex + arrow-key navigation. ---
  const tablist = document.querySelector('[role="tablist"]');
  const tabs = Array.from(document.querySelectorAll('[role="tab"]'));
  const panels = Array.from(document.querySelectorAll('[role="tabpanel"]'));

  function selectTab(tab, setFocus = true) {
    tabs.forEach((t) => {
      const selected = t === tab;
      t.setAttribute('aria-selected', selected ? 'true' : 'false');
      t.setAttribute('tabindex', selected ? '0' : '-1');
    });
    const key = tab.getAttribute('data-tab');
    panels.forEach((p) => {
      if (p.getAttribute('data-panel') === key) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    if (setFocus) tab.focus();
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => selectTab(tab));
  });

  tablist.addEventListener('keydown', (e) => {
    const current = tabs.indexOf(document.activeElement);
    if (current < 0) return;
    let next = -1;
    if (e.key === 'ArrowRight') next = (current + 1) % tabs.length;
    else if (e.key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
    else if (e.key === 'Home') next = 0;
    else if (e.key === 'End') next = tabs.length - 1;
    if (next >= 0) {
      e.preventDefault();
      selectTab(tabs[next]);
    }
  });

  // --- Form: real validation with announced, associated error. ---
  const form = document.getElementById('rig-form');
  const sup = document.getElementById('sup');
  const err = document.getElementById('sup-err');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!sup.value.trim()) {
      sup.setAttribute('aria-invalid', 'true');
      sup.classList.add('input--invalid');
      err.hidden = false;
      sup.focus();
    } else {
      sup.removeAttribute('aria-invalid');
      sup.classList.remove('input--invalid');
      err.hidden = true;
      // pretend-save
    }
  });

  sup.addEventListener('input', () => {
    if (sup.value.trim()) {
      sup.removeAttribute('aria-invalid');
      sup.classList.remove('input--invalid');
      err.hidden = true;
    }
  });
</script>
