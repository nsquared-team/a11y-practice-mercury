---
/**
 * Operations — ACCESSIBLE tree.  Patterns: DATA TABLE + MODAL DIALOG (corrected).
 *
 * Fixes (one-to-one with the root Operations page):
 *  - <table> with <caption>, <th scope="col"> + <button> sort with aria-sort kept
 *    in sync, and <th scope="row"> for the site name (1.3.1, 2.1.1, 4.1.2).
 *  - Select-all and per-row checkboxes have accessible names (4.1.2).
 *  - Status rendered as a text badge, not colour alone (1.4.1).
 *  - Filters grouped in <fieldset><legend> with real <label>s (1.3.1, 3.3.2).
 *  - Selection count lives in an aria-live region (4.1.3).
 *  - "Details" is a real <button>; pagination uses <button> with aria-current.
 *  - Modal is role="dialog" aria-modal aria-labelledby, moves focus in on open and
 *    returns it on close, traps Tab, and closes on Escape (4.1.2, 2.1.2, 2.4.3).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeAccessible from '@components/ChromeAccessible.astro';
import { miningSites } from '@data/sites.js';

const STATUS = { active: 'Active', idle: 'Idle', maintenance: 'Maintenance', offline: 'Offline' };
const BADGE = { active: 'ok', idle: 'muted', maintenance: 'warn', offline: 'crit' };
const minerals = [...new Set(miningSites.map((s) => s.mineralType))];
const statuses = ['active', 'idle', 'maintenance', 'offline'];
const detail = miningSites.map((s) => ({
  id: s.id, name: s.name, location: s.location, mineral: s.mineralType,
  rate: s.extractionRate, status: s.status, personnel: s.personnelCount,
  temp: s.temperature, target: s.dailyTarget, progress: s.dailyProgress,
  equipment: s.equipmentAssigned,
  history: Array.from({ length: 7 }, (_, i) => Math.round(s.extractionRate * (0.82 + 0.04 * i + (i % 2 ? 0.03 : -0.015)))),
}));
const cols = [
  { key: 'name', label: 'Site' }, { key: 'location', label: 'Location' },
  { key: 'mineral', label: 'Mineral' }, { key: 'rate', label: 'Rate (kg/h)', num: true },
  { key: 'personnel', label: 'Crew', num: true }, { key: 'status', label: 'Status' },
];
---
<BaseLayout title="Operations — Discover Mercury Mining Operations" variant="accessible">
  <div class="app">
    <ChromeAccessible active="operations">
      <div class="pagehead">
        <h1>Extraction Sites</h1>
        <p>Monitor and manage all active mining sites across the {miningSites.length}-site network.</p>
      </div>

      <div class="filterbar">
        <fieldset class="filtergroup">
          <legend class="filtergroup__label">Mineral</legend>
          {minerals.map((m, i) => (
            <label class="chk"><input type="checkbox" class="f-mineral" value={m} id={`fm-${i}`} />{m}</label>
          ))}
        </fieldset>
        <fieldset class="filtergroup">
          <legend class="filtergroup__label">Status</legend>
          {statuses.map((s) => (
            <label class="chk"><input type="checkbox" class="f-status" value={s} id={`fs-${s}`} />{STATUS[s]}</label>
          ))}
        </fieldset>
      </div>

      <div class="batchbar" id="batchbar" hidden>
        <strong id="batchcount" aria-live="polite">0 sites selected</strong>
        <button class="btn btn--ghost" type="button">Export</button>
        <button class="btn btn--ghost" type="button">Change status</button>
      </div>

      <div class="card">
        <div class="tablewrap">
          <table class="data" id="sites">
            <caption>All {miningSites.length} extraction sites. Use the column buttons to sort.</caption>
            <thead>
              <tr>
                <th class="selectcol">
                  <input type="checkbox" id="selectall" />
                  <label for="selectall" class="sr-only">Select all sites</label>
                </th>
                {cols.map((c) => (
                  <th scope="col" class={c.num ? 'num' : undefined} aria-sort="none" data-col={c.key}>
                    <button type="button" class="sortbtn" data-key={c.key}>{c.label} <span class="sortbtn__arrow" aria-hidden="true"></span></button>
                  </th>
                ))}
                <th scope="col"><span class="sr-only">Actions</span></th>
              </tr>
            </thead>
            <tbody>
              {miningSites.map((s) => (
                <tr data-id={s.id} data-name={s.name} data-location={s.location} data-mineral={s.mineralType} data-rate={s.extractionRate} data-personnel={s.personnelCount} data-status={s.status}>
                  <td class="selectcol"><input type="checkbox" class="rowsel" aria-label={`Select ${s.name}`} /></td>
                  <th scope="row">{s.name}</th>
                  <td>{s.location}</td>
                  <td>{s.mineralType}</td>
                  <td class="num">{s.extractionRate.toLocaleString()}</td>
                  <td class="num">{s.personnelCount}</td>
                  <td><span class={`badge badge--${BADGE[s.status]}`}>{STATUS[s.status]}</span></td>
                  <td><button type="button" class="btn btn--ghost rowdetails" style="padding:.25rem .6rem" data-id={s.id}>Details<span class="sr-only"> for {s.name}</span></button></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <nav class="pagination" id="pager" aria-label="Sites table pages"></nav>
      </div>
    </ChromeAccessible>
  </div>

  <div class="modal-backdrop" id="backdrop" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modaltitle">
      <div class="modal__head">
        <h2 class="modal__title" id="modaltitle" tabindex="-1">Site detail</h2>
        <button class="modal__close" id="modalclose" type="button" aria-label="Close dialog"><span aria-hidden="true">✕</span></button>
      </div>
      <div class="modal__body" id="modalbody"></div>
      <div class="modal__foot">
        <button class="btn btn--ghost" type="button" id="modalcancel">Close</button>
        <button class="btn btn--primary" type="button">Assign crew</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ detail, STATUS, BADGE }}>
  const table = document.getElementById('sites');
  const tbody = table.querySelector('tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const pager = document.getElementById('pager');
  const pageSize = 8;
  let page = 1, sortKey = null, sortDir = 1;

  const numKeys = new Set(['rate', 'personnel']);
  const val = (tr, key) => (numKeys.has(key) ? Number(tr.dataset[key]) : (tr.dataset[key] || '').toLowerCase());
  const activeFilters = (cls) => Array.from(document.querySelectorAll('.' + cls + ':checked')).map((c) => c.value);
  function filtered() {
    const fm = activeFilters('f-mineral'), fs = activeFilters('f-status');
    return rows.filter((tr) => (!fm.length || fm.includes(tr.dataset.mineral)) && (!fs.length || fs.includes(tr.dataset.status)));
  }
  function render() {
    let list = filtered();
    if (sortKey) list.sort((a, b) => (val(a, sortKey) > val(b, sortKey) ? 1 : val(a, sortKey) < val(b, sortKey) ? -1 : 0) * sortDir);
    list.forEach((tr) => tbody.appendChild(tr));
    rows.forEach((tr) => (tr.hidden = true));
    const pages = Math.max(1, Math.ceil(list.length / pageSize));
    if (page > pages) page = pages;
    const start = (page - 1) * pageSize;
    list.slice(start, start + pageSize).forEach((tr) => (tr.hidden = false));
    pager.innerHTML = '';
    for (let p = 1; p <= pages; p++) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'pagebtn';
      b.textContent = p;
      b.setAttribute('aria-label', 'Page ' + p);
      if (p === page) b.setAttribute('aria-current', 'page');
      b.addEventListener('click', () => { page = p; render(); });
      pager.appendChild(b);
    }
    const info = document.createElement('span');
    info.className = 'pageinfo';
    info.textContent = `${list.length} sites`;
    pager.appendChild(info);
  }

  // Sort: real buttons; keep aria-sort on the <th> in sync.
  table.querySelectorAll('.sortbtn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.key;
      if (sortKey === key) sortDir *= -1; else { sortKey = key; sortDir = 1; }
      table.querySelectorAll('thead th[data-col]').forEach((th) => th.setAttribute('aria-sort', 'none'));
      table.querySelectorAll('.sortbtn__arrow').forEach((a) => (a.textContent = ''));
      const th = table.querySelector(`th[data-col="${key}"]`);
      th.setAttribute('aria-sort', sortDir > 0 ? 'ascending' : 'descending');
      btn.querySelector('.sortbtn__arrow').textContent = sortDir > 0 ? '▲' : '▼';
      render();
    });
  });

  document.querySelectorAll('.f-mineral, .f-status').forEach((c) => c.addEventListener('change', () => { page = 1; render(); }));

  // Selection with a polite live count.
  const batchbar = document.getElementById('batchbar');
  const batchcount = document.getElementById('batchcount');
  function updateSelection() {
    const n = document.querySelectorAll('.rowsel:checked').length;
    batchbar.hidden = n === 0;
    batchcount.textContent = n + (n === 1 ? ' site selected' : ' sites selected');
  }
  document.getElementById('selectall').addEventListener('change', (e) => {
    document.querySelectorAll('.rowsel').forEach((c) => (c.checked = e.target.checked));
    updateSelection();
  });
  document.querySelectorAll('.rowsel').forEach((c) => c.addEventListener('change', updateSelection));

  // Accessible modal: focus management, trap, Escape, focus return.
  const backdrop = document.getElementById('backdrop');
  const modal = backdrop.querySelector('.modal');
  const body = document.getElementById('modalbody');
  const title = document.getElementById('modaltitle');
  let lastFocused = null;
  function spark(history) {
    const max = Math.max(...history), min = Math.min(...history), span = max - min || 1;
    const pts = history.map((v, i) => `${10 + i * 30},${50 - ((v - min) / span) * 40}`).join(' ');
    return `<svg viewBox="0 0 190 60" role="img" aria-label="7-day extraction trend, ${history.join(', ')} kg per hour" class="chart" style="max-width:220px"><polyline points="${pts}" fill="none" stroke="#ff9e3d" stroke-width="2.5"/></svg>`;
  }
  function focusable() {
    return Array.from(modal.querySelectorAll('a[href],button:not([disabled]),input:not([disabled]),[tabindex]:not([tabindex="-1"])')).filter((el) => el.offsetParent !== null);
  }
  function onKeydown(e) {
    if (e.key === 'Escape') { closeModal(); return; }
    if (e.key === 'Tab') {
      const f = focusable(); if (!f.length) return;
      const first = f[0], last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }
  function openModal(id, trigger) {
    const d = detail.find((x) => x.id === id); if (!d) return;
    lastFocused = trigger;
    title.textContent = d.name;
    body.innerHTML = `
      <dl class="detailgrid">
        <div class="detailitem"><dt>Location</dt><dd>${d.location}</dd></div>
        <div class="detailitem"><dt>Mineral</dt><dd>${d.mineral}</dd></div>
        <div class="detailitem"><dt>Rate</dt><dd>${d.rate.toLocaleString()} kg/h</dd></div>
        <div class="detailitem"><dt>Crew</dt><dd>${d.personnel}</dd></div>
        <div class="detailitem"><dt>Surface temp</dt><dd>${d.temp}°C</dd></div>
        <div class="detailitem"><dt>Status</dt><dd>${STATUS[d.status]}</dd></div>
      </dl>
      <p class="muted" style="margin:0 0 .3rem">Daily progress: ${d.progress.toLocaleString()} / ${d.target.toLocaleString()} kg</p>
      <div class="meter" role="progressbar" aria-valuenow="${Math.min(100, Math.round(d.progress / d.target * 100))}" aria-valuemin="0" aria-valuemax="100" aria-label="Daily extraction target progress" style="margin-bottom:1rem"><div class="meter__fill" style="width:${Math.min(100, Math.round(d.progress / d.target * 100))}%"></div></div>
      <p class="muted" style="margin:0 0 .3rem">7-day extraction history</p>
      ${spark(d.history)}`;
    backdrop.hidden = false;
    document.addEventListener('keydown', onKeydown);
    title.focus();
  }
  function closeModal() {
    backdrop.hidden = true;
    document.removeEventListener('keydown', onKeydown);
    if (lastFocused) lastFocused.focus();
  }
  document.querySelectorAll('.rowdetails').forEach((el) => el.addEventListener('click', () => openModal(el.dataset.id, el)));
  document.getElementById('modalclose').addEventListener('click', closeModal);
  document.getElementById('modalcancel').addEventListener('click', closeModal);
  backdrop.addEventListener('click', (e) => { if (e.target === backdrop) closeModal(); });

  render();
</script>
