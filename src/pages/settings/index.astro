---
/**
 * Settings — ROOT (inaccessible) tree.  Pattern focus: TABS + TOGGLE SWITCHES +
 * RANGE SLIDERS + DASHBOARD WIDGET REORDER + ACCOUNT FORM.
 *
 * Deliberate WCAG failures on this page:
 *  TABS:
 *   - Tabs are clickable <div>s with NO role="tab"/"tablist"/"tabpanel", no
 *     aria-selected/controls, no keyboard support; selected state is COLOUR ONLY
 *     via .is-active (4.1.2 / 2.1.1 / 1.4.1).
 *  DISPLAY:
 *   - The preference <select>s have NO associated <label> — only a nearby text
 *     <div> (1.3.1 / 3.3.2 / 4.1.2).
 *   - Toggle switches are custom clickable <div>s: no role="switch", no
 *     aria-checked, not focusable, not keyboard operable, state by colour /
 *     thumb position only (2.1.1 / 4.1.2 / 1.4.1).
 *  NOTIFICATIONS:
 *   - Range <input type=range> sliders have NO <label> / accessible name; the
 *     value text is a loose span not tied to the control (1.3.1 / 4.1.2).
 *   - Category toggles are the same custom <div> switches (2.1.1 / 4.1.2).
 *  DASHBOARD:
 *   - Widgets reorder by mouse drag only — no keyboard alternative (2.1.1); the
 *     show/hide control is a clickable <span> with no name, state by icon/colour
 *     (4.1.2 / 1.4.1); "Reset" is a clickable <div>, not a button (4.1.2).
 *  ACCOUNT:
 *   - Inputs are placeholder-only, no <label> (1.3.1 / 3.3.2); "Save" is a
 *     clickable <div>, not a button (4.1.2).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeRoot from '@components/ChromeRoot.astro';
import {
  SETTINGS_TABS, DISPLAY_PREFS, DISPLAY_TOGGLES, NOTIFICATION_SLIDERS,
  NOTIFICATION_CATEGORIES, DASHBOARD_WIDGETS, ACCOUNT,
} from '@data/ops.js';
---
<BaseLayout title="Settings — Discover Mercury Mining Operations" variant="root">
  <div class="app">
    <ChromeRoot active="settings">
      <div class="pagehead">
        <h1>Settings</h1>
        <p>Configure display, notifications, dashboard layout, and your account.</p>
      </div>

      <div class="tabs">
        {/* Clickable divs, no tab semantics, no keyboard, colour-only state. */}
        <div class="tablist">
          {SETTINGS_TABS.map((t, i) => (
            <div class={`tab${i === 0 ? ' is-active' : ''}`} data-tab={t.key}>{t.label}</div>
          ))}
        </div>

        {/* Display */}
        <div class="tabpanel" data-panel="display">
          <h2 class="section__title">Display preferences</h2>
          {DISPLAY_PREFS.map((p) => (
            <div class="prefrow">
              <div class="prefrow__text">
                <div class="prefrow__label">{p.label}</div>
                <div class="prefrow__hint">{p.hint}</div>
              </div>
              <select class="select prefrow__control" data-pref={p.key}>
                {p.options.map((o) => (
                  <option value={o.value} selected={o.value === p.value}>{o.label}</option>
                ))}
              </select>
            </div>
          ))}

          <h2 class="section__title" style="margin-top:1.4rem">Console</h2>
          {DISPLAY_TOGGLES.map((t) => (
            <div class="prefrow">
              <div class="prefrow__text">
                <div class="prefrow__label">{t.label}</div>
                <div class="prefrow__hint">{t.description}</div>
              </div>
              {/* Custom div switch: click only, no role/aria/keyboard. */}
              <div class={`switch${t.on ? ' is-on' : ''}`} data-toggle={t.key}>
                <span class="switch__thumb"></span>
              </div>
            </div>
          ))}
        </div>

        {/* Notifications */}
        <div class="tabpanel" data-panel="notifications" hidden>
          <h2 class="section__title">Notification sliders</h2>
          {NOTIFICATION_SLIDERS.map((s) => (
            <div class="sliderrow">
              <div class="prefrow__text">
                <div class="prefrow__label">{s.label}</div>
                <div class="prefrow__hint">{s.description}</div>
              </div>
              <div class="sliderrow__control">
                {/* Range with no label / accessible name; loose value span. */}
                <input class="range" type="range" min={s.min} max={s.max} value={s.value} data-slider={s.key} />
                <span class="sliderrow__value" data-slider-value={s.key}>{s.value}{s.unit}</span>
              </div>
            </div>
          ))}

          <h2 class="section__title" style="margin-top:1.4rem">Alert categories</h2>
          {NOTIFICATION_CATEGORIES.map((c) => (
            <div class="prefrow">
              <div class="prefrow__text">
                <div class="prefrow__label">{c.label}</div>
              </div>
              <div class={`switch switch--sm${c.on ? ' is-on' : ''}`} data-toggle={`cat-${c.key}`}>
                <span class="switch__thumb"></span>
              </div>
            </div>
          ))}
        </div>

        {/* Dashboard */}
        <div class="tabpanel" data-panel="dashboard" hidden>
          <h2 class="section__title">Dashboard widgets</h2>
          <div class="toolbar">
            <span class="muted" id="widget-count">{DASHBOARD_WIDGETS.filter((w) => w.enabled).length} of {DASHBOARD_WIDGETS.length} widgets visible</span>
            {/* Clickable div, not a button. */}
            <div class="btn btn--ghost" id="widget-reset" data-reset>Reset to default</div>
          </div>
          <p class="muted">Drag widgets to reorder them on the dashboard.</p>
          <ul class="roster widgetlist" id="widgetlist">
            {DASHBOARD_WIDGETS.map((w) => (
              <li class={`rosteritem widgetitem${w.enabled ? '' : ' is-hidden'}`} draggable="true" data-id={w.id} data-enabled={w.enabled ? '1' : '0'}>
                <span class="rosteritem__grip">⋮⋮</span>
                <span class="rosteritem__name">{w.name}</span>
                {/* Clickable span show/hide, no name, icon/colour only. */}
                <span class="widgetitem__vis" data-vis>{w.enabled ? '👁' : '🚫'}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Account */}
        <div class="tabpanel" data-panel="account" hidden>
          <h2 class="section__title">Account information</h2>
          <form id="account-form" class="stack">
            <div class="field">
              {/* Placeholder-only, no label. */}
              <input class="input" type="text" name="displayName" placeholder="Display name" value={ACCOUNT.displayName} />
            </div>
            <div class="field">
              <input class="input" type="email" name="email" placeholder="Email" value={ACCOUNT.email} />
            </div>
            <div class="field">
              <input class="input" type="text" name="role" placeholder="Role" value={ACCOUNT.role} />
            </div>
            {/* Clickable div, not a button. */}
            <div class="btn btn--primary" id="account-save" data-save>Save changes</div>
          </form>
        </div>
      </div>
    </ChromeRoot>
  </div>
</BaseLayout>

<script>
  // Tabs: click-only switching, selection by .is-active class only.
  const tabs = Array.from(document.querySelectorAll('.tab'));
  const panels = Array.from(document.querySelectorAll('.tabpanel'));
  function selectTab(key) {
    tabs.forEach((t) => t.classList.toggle('is-active', t.getAttribute('data-tab') === key));
    panels.forEach((p) => {
      if (p.getAttribute('data-panel') === key) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
  }
  tabs.forEach((t) => t.addEventListener('click', () => selectTab(t.getAttribute('data-tab'))));

  // Toggles: flip a class on click. No state object, no keyboard.
  document.querySelectorAll('[data-toggle]').forEach((sw) => {
    sw.addEventListener('click', () => sw.classList.toggle('is-on'));
  });

  // Sliders: update the loose value span.
  document.querySelectorAll('[data-slider]').forEach((sl) => {
    const out = document.querySelector('[data-slider-value="' + sl.getAttribute('data-slider') + '"]');
    const unit = out && /%/.test(out.textContent) ? '%' : '';
    sl.addEventListener('input', () => { if (out) out.textContent = sl.value + unit; });
  });

  // Widget list: pointer drag reorder + show/hide + reset.
  const list = document.getElementById('widgetlist');
  const countEl = document.getElementById('widget-count');
  const total = list.querySelectorAll('.widgetitem').length;
  function updateCount() {
    const on = list.querySelectorAll('.widgetitem[data-enabled="1"]').length;
    countEl.textContent = on + ' of ' + total + ' widgets visible';
  }
  let dragged = null;
  list.querySelectorAll('.widgetitem').forEach((li) => {
    li.addEventListener('dragstart', () => { dragged = li; li.classList.add('dragging'); });
    li.addEventListener('dragend', () => { dragged && dragged.classList.remove('dragging'); dragged = null; });
    li.querySelector('[data-vis]').addEventListener('click', () => {
      const on = li.getAttribute('data-enabled') === '1';
      li.setAttribute('data-enabled', on ? '0' : '1');
      li.classList.toggle('is-hidden', on);
      li.querySelector('[data-vis]').textContent = on ? '🚫' : '👁';
      updateCount();
    });
  });
  list.addEventListener('dragover', (e) => {
    e.preventDefault();
    if (!dragged) return;
    const after = [...list.querySelectorAll('.widgetitem:not(.dragging)')]
      .find((el) => e.clientY < el.getBoundingClientRect().top + el.offsetHeight / 2);
    if (after) list.insertBefore(dragged, after); else list.appendChild(dragged);
  });

  document.querySelector('[data-reset]').addEventListener('click', () => {
    list.querySelectorAll('.widgetitem').forEach((li) => {
      li.setAttribute('data-enabled', '1');
      li.classList.remove('is-hidden');
      li.querySelector('[data-vis]').textContent = '👁';
    });
    updateCount();
  });

  // Account save: clickable div (no real submit).
  const aform = document.getElementById('account-form');
  aform.addEventListener('submit', (e) => e.preventDefault());
  document.querySelector('[data-save]').addEventListener('click', () => { /* pretend-save */ });
</script>
