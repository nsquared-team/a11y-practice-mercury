---
/**
 * Dashboard — ROOT (inaccessible) tree.  Patterns: CHARTS + status grid +
 * commodity widget + alert feed.
 *
 * Deliberate WCAG failures:
 *  - Banner is a styled <div>, not a live/alert region (4.1.3).
 *  - KPI deltas use ▲/▼ glyph + colour only, no text (1.4.1).
 *  - Extraction chart <svg> has no name/role/alt and no data table (1.1.1).
 *  - Equipment status grid: cells are non-focusable <div>s, status only in a
 *    `title` attribute and by colour (1.1.1, 1.4.1, 2.1.1).
 *  - Alert feed is a <div> stack (no list semantics), severity by left-border
 *    colour only, no text label (1.3.1, 1.4.1).
 *  - Commodity price change conveyed by colour only, no icon/text direction
 *    (1.4.1). Names/symbols low-contrast (1.4.3, via the override).
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ChromeRoot from '@components/ChromeRoot.astro';
import { SITE, KPIS, EXTRACTION_SERIES } from '@data/ops.js';
import { commoditiesData, getRecentAlerts, formatAlertTime } from '@data/alerts.js';
import { equipmentData } from '@data/equipment.js';
import { multiSeriesPlot } from '@lib/chart.js';

const plot = multiSeriesPlot(EXTRACTION_SERIES.labels, EXTRACTION_SERIES.series);
const recent = getRecentAlerts(4);
const EQ = { operational: 'operational', idle: 'idle', maintenance: 'maintenance', offline: 'offline' };
---
<BaseLayout title="Dashboard — Discover Mercury Mining Operations" variant="root">
  <div class="app">
    <ChromeRoot active="dashboard">
      <div class="pagehead">
        <h1>Operations Dashboard</h1>
        <p>Live extraction telemetry for the {SITE.colony}.</p>
      </div>

      <div class="banner banner--critical">
        <span class="live-dot"></span>
        Rig 07 auto-halted — drill head over-torque. Inspection crew dispatched.
      </div>

      <div class="grid grid--kpi" style="margin-bottom:1rem">
        {KPIS.map((k) => (
          <div class="card">
            <div class="kpi__label">{k.label}</div>
            <div class="kpi__value">{k.value} <span class="kpi__unit">{k.unit}</span></div>
            <div class={`kpi__delta ${k.delta > 0 ? 'kpi__delta--up' : k.delta < 0 ? 'kpi__delta--down' : 'kpi__delta--flat'}`}>
              {k.delta > 0 ? '▲' : k.delta < 0 ? '▼' : '■'} {Math.abs(k.delta)}%
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid--2">
        {/* Extraction chart: no name/role/alt, no data table. */}
        <div class="card">
          <div class="card__title"><h3>{EXTRACTION_SERIES.label}</h3></div>
          <svg class="chart" viewBox={`0 0 ${plot.width} ${plot.height}`}>
            <line class="chart__axis" x1={plot.pad} y1={plot.baseline} x2={plot.width - plot.pad} y2={plot.baseline} />
            {plot.series.map((s) => (
              <g>
                <path class="chart__series-area" d={s.area} fill={s.color} />
                <path d={s.line} fill="none" stroke={s.color} stroke-width="2.5" />
              </g>
            ))}
            {plot.labels.filter((_, i) => i % 2 === 0).map((t, i) => (
              <text class="chart__label" x={plot.x[i * 2]} y={plot.baseline + 14} text-anchor="middle">{t}</text>
            ))}
          </svg>
          <div class="legend">
            {plot.series.map((s) => (
              <span class="legend__item"><span class="legend__swatch" style={`background:${s.color}`}></span>{s.label}</span>
            ))}
          </div>
        </div>

        {/* Alert feed: div stack, severity by colour only, no list semantics. */}
        <div class="card">
          <div class="card__title"><h3>Recent alerts</h3></div>
          <div class="minifeed">
            {recent.map((a) => (
              <div class={`minialert minialert--${a.severity}`}>
                <p class="minialert__title">{a.title}</p>
                <span class="minialert__time">{formatAlertTime(a.timestamp)}</span>
                <p class="minialert__msg">{a.message}</p>
              </div>
            ))}
          </div>
          <a class="feedlink" href="/alerts/">View all alerts →</a>
        </div>
      </div>

      <div class="grid grid--2" style="margin-top:1rem">
        {/* Equipment status grid: colour-only, non-focusable, info in title only. */}
        <div class="card">
          <div class="card__title"><h3>Equipment status</h3></div>
          <div class="eqgrid">
            {equipmentData.map((e) => (
              <div class={`eqcell eqcell--${EQ[e.status]}`} title={`${e.name}: ${e.status}`}></div>
            ))}
          </div>
          <div class="eqlegend">
            <span class="legend__item"><span class="legend__swatch eqcell--operational"></span>Operational</span>
            <span class="legend__item"><span class="legend__swatch eqcell--idle"></span>Idle</span>
            <span class="legend__item"><span class="legend__swatch eqcell--maintenance"></span>Maintenance</span>
            <span class="legend__item"><span class="legend__swatch eqcell--offline"></span>Offline</span>
          </div>
        </div>

        {/* Commodity prices: change by colour only, no direction text/icon. */}
        <div class="card">
          <div class="card__title"><h3>Commodity prices</h3></div>
          <div class="commoditylist">
            {commoditiesData.map((c) => (
              <div class="commodity">
                <span class="commodity__name">
                  {c.name}
                  <span class="commodity__sym">{c.symbol}</span>
                </span>
                <span class="commodity__price">{c.price.toLocaleString()} ¢</span>
                <span class={`commodity__chg commodity__chg--${c.trend === 'up' ? 'up' : c.trend === 'down' ? 'down' : 'stable'}`}>
                  {c.change24h > 0 ? '+' : ''}{c.change24h}%
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </ChromeRoot>
  </div>
</BaseLayout>
